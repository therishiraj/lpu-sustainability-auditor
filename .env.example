# Required — get a free key at https://aistudio.google.com
# (This is a Gemini API key, separate from a Gemini/Google AI Pro chat subscription.)
GEMINI_API_KEY=your-gemini-api-key-here

# Optional but recommended — automatic fallback when the Gemini free-tier
# quota is exhausted. Get a free key (no credit card) at
# https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
